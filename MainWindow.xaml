<Window x:Class="SecuroTronGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Securo-Tron | Cybersecurity Awareness Bot"
        Height="700" Width="900"
        MinHeight="600" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">

    <Window.Resources>
        <!-- Button Style -->
        <Style x:Key="ChatButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2EA043"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1A7F37"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input TextBox Style -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="CaretBrush" Value="#58A6FF"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#58A6FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#161B22" 
                BorderBrush="#30363D" BorderThickness="0,0,0,1"
                Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Bot Avatar -->
                <Border Grid.Column="0" Width="50" Height="50"
                        Background="#21262D" CornerRadius="25"
                        BorderBrush="#58A6FF" BorderThickness="2"
                        Margin="0,0,15,0">
                    <TextBlock Text="🤖" FontSize="24"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Title -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Securo-Tron" 
                               Foreground="#58A6FF"
                               FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="Cybersecurity Awareness Assistant" 
                               Foreground="#8B949E"
                               FontSize="12"/>
                </StackPanel>

                <!-- Status indicator -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#3FB950" 
                             Margin="0,0,6,0"/>
                    <TextBlock Text="Online" Foreground="#3FB950" 
                               FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── ASCII Art Banner ───────────────────────────────── -->
<Border Grid.Row="1" Background="#161B22" 
        BorderBrush="#30363D" BorderThickness="0,0,0,1"
        Padding="10,12">
    <StackPanel HorizontalAlignment="Center">
        <TextBlock FontSize="24" FontWeight="Bold"
                   Foreground="#58A6FF" HorizontalAlignment="Center"
                   Text="[ SECURO-TRON ]"/>
        <TextBlock FontSize="12"
                   Foreground="#3FB950" HorizontalAlignment="Center"
                   Margin="0,4,0,0"
                   Text=" Keeping South Africa Safe Online "/>
    </StackPanel>
</Border>

        <!-- ── Chat Area ──────────────────────────────────────── -->
        <Border Grid.Row="2" Margin="15,10,15,5"
                Background="#161B22" CornerRadius="8"
                BorderBrush="#30363D" BorderThickness="1">
            <ScrollViewer x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Padding="10">
                <StackPanel x:Name="ChatPanel"/>
            </ScrollViewer>
        </Border>

        <!-- ── Input Area ─────────────────────────────────────── -->
        <Border Grid.Row="3" Background="#161B22"
                BorderBrush="#30363D" BorderThickness="0,1,0,0"
                Padding="15,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInputBox"
                         Grid.Column="0"
                         Style="{StaticResource InputStyle}"
                         KeyDown="UserInputBox_KeyDown"
                         Margin="0,0,10,0"/>

                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="Send"
                        Style="{StaticResource ChatButtonStyle}"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>